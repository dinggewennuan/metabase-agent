OPENAI_API_KEY=
# OpenAI 兼容网关地址；留空/默认为官方 API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5
# chat_completions（默认，走 SDK）；chat_completions_httpx（同一端点但用裸 httpx——
# 网关 WAF 拦 SDK 请求指纹返回 403 "Your request was blocked" 时用这个）；
# responses（/responses 端点，裸 httpx，仅部分自建网关需要）
OPENAI_WIRE_API=chat_completions
# LLM 请求超时（秒），换网关时可调
OPENAI_TIMEOUT=120
# SiliconFlow embedding API key；AGENT_EMBEDDING_PROVIDER=siliconflow 时必填
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
METABASE_BASE_URL=https://your-metabase.example.com
METABASE_API_KEY=
AGENT_DRY_RUN=true
# pipeline = 固定规则管道（默认）；tools = LLM 工具循环 Agent（需 OPENAI_API_KEY）
AGENT_MODE=pipeline
AGENT_MEMORY_PATH=.metabase_agent_memory.json
# 挂起审批 / 表上下文持久化文件（重启不丢）
AGENT_STATE_PATH=.metabase_agent_state.json
# 状态后端：memory = 进程内 + JSON（单 worker）；sqlite = 多 worker 共享（AGENT_STATE_PATH 指向 .db 文件）
AGENT_STORE=memory
# 会话 TTL（秒），0 = 不过期；仅 sqlite 后端生效
AGENT_SESSION_TTL_SECONDS=0
# LangGraph checkpoint：none = 不启用；mongodb = 用 MongoDBSaver 保存 graph thread 状态
AGENT_CHECKPOINT_BACKEND=none
AGENT_CHECKPOINT_MONGODB_URI=
AGENT_CHECKPOINT_MONGODB_DATABASE=metabase_agent_checkpoints
AGENT_CHECKPOINT_TTL_SECONDS=0
# 长期记忆身份隔离；API 请求也可传 tenant_id/user_id 覆盖
AGENT_TENANT_ID=default
AGENT_USER_ID=
# 结构化长期记忆：MongoDB 存完整 memory record，pgvector 存 embedding 索引
AGENT_LONG_TERM_MEMORY_ENABLED=false
# 默认留空（与代码默认一致）；启用长期记忆时按下面示例填写
AGENT_MONGODB_URI=
# AGENT_MONGODB_URI=mongodb://127.0.0.1:27017
AGENT_MONGODB_DATABASE=metabase_agent
AGENT_MEMORY_COLLECTION=agent_memories
AGENT_PGVECTOR_DSN=
# AGENT_PGVECTOR_DSN=postgresql://user:pass@127.0.0.1:5432/metabase_agent
AGENT_PGVECTOR_TABLE=memory_embeddings
AGENT_EMBEDDING_PROVIDER=hash
AGENT_EMBEDDING_MODEL=text-embedding-3-small
AGENT_EMBEDDING_DIMENSIONS=1536
# SiliconFlow 示例：
# AGENT_EMBEDDING_PROVIDER=siliconflow
# AGENT_EMBEDDING_MODEL=BAAI/bge-m3
# AGENT_EMBEDDING_DIMENSIONS=1024
# Skills progressive loading
AGENT_SKILLS_ENABLED=true
AGENT_SKILLS_PATH=skills
AGENT_SKILLS_MAX_CHARS=6000
# 留空 = 本地无鉴权；设置后 /api/ask、/api/ask/stream、/api/sessions 需携带 X-Agent-Token 头
AGENT_API_TOKEN=
# true = 强制要求 token；若未配置 AGENT_API_TOKEN 则直接拒绝所有 /api 请求（防止误暴露）
AGENT_REQUIRE_TOKEN=false
# 换 Metabase 实例时改这里：BigQuery 库的数据库 id（原先写死为 19）
METABASE_BIGQUERY_DATABASE_ID=19
# 月度用量报表的时间范围与时区（不再写死在代码里）
AGENT_REPORT_RANGE_START=2025-11-01
AGENT_REPORT_RANGE_END_EXCLUSIVE=2026-05-01
AGENT_REPORT_TIMEZONE=US/Pacific
