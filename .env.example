OPENAI_API_KEY=
OPENAI_BASE_URL=https://ai.akool.icu
OPENAI_MODEL=gpt-5
OPENAI_WIRE_API=responses
METABASE_BASE_URL=https://akool.metabaseapp.com
METABASE_API_KEY=
AGENT_DRY_RUN=true
AGENT_MEMORY_PATH=.metabase_agent_memory.json
# 挂起审批 / 表上下文持久化文件（重启不丢）
AGENT_STATE_PATH=.metabase_agent_state.json
# 留空 = 本地无鉴权；设置后 /api/ask、/api/ask/stream、/api/sessions 需携带 X-Agent-Token 头
AGENT_API_TOKEN=
# 换 Metabase 实例时改这里：BigQuery 库的数据库 id（原先写死为 19）
METABASE_BIGQUERY_DATABASE_ID=19
# 月度用量报表的时间范围与时区（不再写死在代码里）
AGENT_REPORT_RANGE_START=2025-11-01
AGENT_REPORT_RANGE_END_EXCLUSIVE=2026-05-01
AGENT_REPORT_TIMEZONE=US/Pacific
